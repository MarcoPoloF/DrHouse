<?xml version="1.0" encoding="utf-8" ?>
<!--Definición de View (XAML): Datos Personales (dn-37-3).-->
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://xamarin.com/schemas/2014/forms/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:Behaviors="clr-namespace:DocNoc.Xam.Behaviors"
             xmlns:Controls="clr-namespace:DocNoc.Xam.Controls"
             xmlns:Converters="clr-namespace:DocNoc.Xam.Converters"
             xmlns:SfBorder="clr-namespace:Syncfusion.XForms.Border;assembly=Syncfusion.Core.XForms"
             xmlns:SfButtons="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
             mc:Ignorable="d"
             x:Class="DocNoc.Xam.Views.Usuarios.CambiarPasswordView"
             x:Name="CambiarPasswordPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackground}">

    <!-- ContentPage: Resources -->
    <ContentPage.Resources>
        <ResourceDictionary>
            <Converters:BooleanToColorConverter x:Key="ColorConverter" />
            <!-- Merged Dictionaries -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- ContentPage: TitleView -->
    <ContentPage.ControlTemplate>
        <ControlTemplate>
            <StackLayout x:Name="TitleLayout" Spacing="0">
                <StackLayout.Padding>
                    <OnPlatform x:TypeArguments="Thickness">
                        <OnPlatform.Platforms>
                            <On Platform="iOS" Value="0, 36, 0, 0" />
                        </OnPlatform.Platforms>
                    </OnPlatform>
                </StackLayout.Padding>
                <Controls:TitleView Title="Cambiar Contraseña">
                    <Controls:TitleView.LeadingView>
                        <!-- Button: Back -->
                        <SfButtons:SfButton x:Name="BackButton" CornerRadius="4" Text="{StaticResource Back}"
                                            Command="{Binding Path=BindingContext.BackCommand, Source={x:Reference CambiarPasswordPage}}" 
                                            CommandParameter="{x:Reference BackButton}" Style="{StaticResource IconButtonStyle}"/>
                    </Controls:TitleView.LeadingView>
                </Controls:TitleView>
                <ContentPresenter />
            </StackLayout>
        </ControlTemplate>
    </ContentPage.ControlTemplate>

    <!-- ContentPage: Content -->
    <ContentPage.Content>

        <!-- Grid: Page-->
        <Grid>
            <!--ScrollView: Page -->
            <ScrollView HorizontalOptions="FillAndExpand">
                <!-- ScrollView Options -->
                <ScrollView.VerticalOptions>
                    <OnIdiom 
                        x:TypeArguments="LayoutOptions"
                        Default="CenterAndExpand"
                        Phone="FillAndExpand" />
                </ScrollView.VerticalOptions>

                <StackLayout Spacing="20" Padding="0,20">

                    <Label
                        x:Name="ResetPasswordLabel"
                        FontFamily="{StaticResource Montserrat-SemiBold}"
                        HorizontalOptions="End"
                        HorizontalTextAlignment="End"
                        Text="¿OLVIDASTE LA CONTRASEÑA?"
                        TextColor="DarkBlue"
                        Margin="0,20,10,20">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ResetPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <StackLayout BackgroundColor="White" HorizontalOptions="FillAndExpand" Padding="10,0">

                        <SfBorder:SfBorder BorderColor="{Binding Source={x:Reference OldPasswordEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}" Style="{StaticResource FormBorderStyle}">
                            <Controls:BorderlessEntry
                                x:Name="OldPasswordEntry" IsPassword="True"
                                Placeholder="Contraseña actual" Text="{Binding PasswordActual}"
                                Style="{StaticResource EntryTextStyle}">
                                <Controls:BorderlessEntry.Behaviors>
                                    <Behaviors:EventToCommandBehavior EventName="TextChanged" Command="{Binding CheckChangesCommand}"/>
                                </Controls:BorderlessEntry.Behaviors>
                            </Controls:BorderlessEntry>
                        </SfBorder:SfBorder>

                        <SfBorder:SfBorder BorderColor="{Binding Source={x:Reference NewPasswordEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}" Style="{StaticResource FormBorderStyle}">
                            <Controls:BorderlessEntry
                                x:Name="NewPasswordEntry" IsPassword="True"
                                Placeholder="Nueva contraseña" Text="{Binding PasswordNuevo}"
                                Style="{StaticResource EntryTextStyle}">
                                <Controls:BorderlessEntry.Behaviors>
                                    <Behaviors:EventToCommandBehavior EventName="TextChanged" Command="{Binding CheckChangesCommand}"/>
                                </Controls:BorderlessEntry.Behaviors>
                            </Controls:BorderlessEntry>
                        </SfBorder:SfBorder>

                        <SfBorder:SfBorder BorderColor="{Binding Source={x:Reference ConfirmPasswordEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}" Style="{StaticResource FormBorderStyle}">
                            <Controls:BorderlessEntry
                                x:Name="ConfirmPasswordEntry" IsPassword="True"
                                Placeholder="Confirmar contraseña" Text="{Binding PasswordConfirmacion}"
                                Style="{StaticResource EntryTextStyle}">
                                <Controls:BorderlessEntry.Behaviors>
                                    <Behaviors:EventToCommandBehavior EventName="TextChanged" Command="{Binding CheckChangesCommand}"/>
                                </Controls:BorderlessEntry.Behaviors>
                            </Controls:BorderlessEntry>
                        </SfBorder:SfBorder>

                        <Label
                            FontFamily="{StaticResource Montserrat-SemiBold}"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Text="Las contraseñas no coinciden"
                            TextColor="DarkRed"
                            Margin="0,0,0,10"
                            IsVisible="{Binding PasswordsDistintos}"/>

                    </StackLayout>

                    <StackLayout Spacing="10" Padding="50,0" IsVisible="{Binding HayDatos}">

                        <SfButtons:SfButton Text="Guardar" Command="{Binding UpdateCommand}" CornerRadius="20" 
                                            Style="{StaticResource GradientButtonStyle}" IsVisible="{Binding DatosValidos}"/>

                        <Label
                            x:Name="CancelLabel"
                            FontFamily="{StaticResource Montserrat-SemiBold}"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Text="Cancelar"
                            TextColor="LightGray">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </StackLayout>

                </StackLayout>

            </ScrollView>
        </Grid>
        
    </ContentPage.Content>

</ContentPage>