<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DocNoc.Xam.Views.Medicos.ContactProfilePage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns="http://xamarin.com/schemas/2014/forms"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://xamarin.com/schemas/2014/forms/design"
    xmlns:border="clr-namespace:Syncfusion.XForms.Border;assembly=Syncfusion.Core.XForms"
    xmlns:button="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
    xmlns:Controls="clr-namespace:DocNoc.Xam.Controls"
    xmlns:Converters="clr-namespace:DocNoc.Xam.Converters"
    xmlns:SfButtons="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
    xmlns:SfListView="clr-namespace:Syncfusion.ListView.XForms;assembly=Syncfusion.SfListView.XForms"
    xmlns:SfRating="clr-namespace:Syncfusion.SfRating.XForms;assembly=Syncfusion.SfRating.XForms"
    xmlns:helper="clr-namespace:DocNoc.Xam.Helpers"
    xmlns:Styles="clr-namespace:DocNoc.Xam.Styles;assembly=DocNoc.Xam"
    mc:Ignorable="d"
    x:Name="PerfilMedicoPage"
    Title="Perfil de Médico"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{DynamicResource PageBackground}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml" />
                <!-- Resource Dictionary: Main Stylesheet -->
                <Styles:MainStylesheet/>
            </ResourceDictionary.MergedDictionaries>
            <Converters:InverseBooleanConverter x:Key="InverseBoolean" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- ContentPage: TitleView -->
    <ContentPage.ControlTemplate>
        <ControlTemplate>
            <StackLayout x:Name="TitleLayout" Spacing="0">
                <StackLayout.Padding>
                    <OnPlatform x:TypeArguments="Thickness">
                        <OnPlatform.Platforms>
                            <On Platform="iOS" Value="0, 36, 0, 0" />
                        </OnPlatform.Platforms>
                    </OnPlatform>
                </StackLayout.Padding>
                <Controls:TitleView Title="Perfil de Médico">
                    <Controls:TitleView.LeadingView>
                        <!-- Button: Back -->
                        <SfButtons:SfButton x:Name="BackButton" CornerRadius="4" Text="{StaticResource Back}"
                                            Command="{Binding Path=BindingContext.BackCommand, Source={x:Reference PerfilMedicoPage}}" 
                                            CommandParameter="{x:Reference BackButton}" Style="{StaticResource IconButtonStyle}"/>
                    </Controls:TitleView.LeadingView>
                </Controls:TitleView>
                <ContentPresenter />
            </StackLayout>
        </ControlTemplate>
    </ContentPage.ControlTemplate>

    <ContentPage.Content>
        <ScrollView>

            <StackLayout HorizontalOptions="FillAndExpand" BackgroundColor="Transparent" Spacing="20">

                <StackLayout HorizontalOptions="FillAndExpand" BackgroundColor="White" Spacing="0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Image
                        x:Name="ProfileImage"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Aspect="AspectFill"
                        BackgroundColor="{DynamicResource Gray-200}"
                        HeightRequest="{OnIdiom Default=480,
                                                Phone=330}" >
                            <Image.Source>
                                <UriImageSource
                                CacheValidity="14"
                                CachingEnabled="true"
                                Uri="{Binding Medico.RutaImagen}" />
                            </Image.Source>
                        </Image>

                        <StackLayout Grid.Row="0" Grid.Column="2" Padding="20" VerticalOptions="Start" IsVisible="{Binding MostrarEstatusFavorito}">
                            <!--Add to Favorites-->
                            <border:SfBorder BackgroundColor="{DynamicResource White}" WidthRequest="33" Padding="0,2,0,0"
                                         BorderWidth="0" CornerRadius="48" IsVisible="{Binding EsFavorito, Converter={StaticResource InverseBoolean}}">
                                <border:SfBorder.Content>
                                    <Image Source="favoriteempty.png" HeightRequest="33" HorizontalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding AgregarFavoritoCommand}"/>
                                        </Image.GestureRecognizers>
                                    </Image>
                                </border:SfBorder.Content>
                            </border:SfBorder>
                            <!--Remove from Favorites-->
                            <border:SfBorder BackgroundColor="{DynamicResource White}" WidthRequest="33"
                                         BorderWidth="0" CornerRadius="33" IsVisible="{Binding EsFavorito}">
                                <border:SfBorder.Content>
                                    <Image Source="favoritefull.png" HeightRequest="33" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding RemoverFavoritoCommand}"/>
                                        </Image.GestureRecognizers>
                                    </Image>
                                </border:SfBorder.Content>
                            </border:SfBorder>
                        </StackLayout>

                        <!--  Profile name and status with border  -->
                        <border:SfBorder
                        x:Name="ProfileNameLabel"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        helper:RTLHelper.CornerRadius="{OnIdiom Default='32,32,0,0'}"
                        BackgroundColor="{DynamicResource Gray-White}"
                        BorderWidth="0"
                        VerticalOptions="End">
                            <border:SfBorder.Content>
                                <Grid
                                Margin="0,32,0,0"
                                Padding="20,10"
                                ColumnSpacing="8"
                                RowSpacing="0">

                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Status Icon  -->
                                    <Label
                                    Grid.Column="0"
                                    FontSize="24"
                                    HorizontalTextAlignment="End"
                                    Style="{StaticResource CommonProfileIconLabelStyle}"
                                    Text="{StaticResource Available}"
                                    TextColor="{Binding ColorEstatus}" />

                                    <!--  Profile Name  -->
                                    <Label Grid.Row="0" Grid.Column="1"
                                    Style="{StaticResource LabelStyle-Title}"
                                    Text="{Binding Medico.NombreCompleto}"/>

                                    <!--  Status  -->
                                    <Label Grid.Row="1" Grid.Column="1"
                                    Text="{Binding EstatusLetra}" 
                                    Style="{StaticResource LabelStyle-Text}"/>

                                    <Image Grid.RowSpan="2" Grid.Column="2" Source="sendmessage.png" HeightRequest="36"
                                       IsVisible="{Binding ChatDisponible}">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding AbrirChatCommand}"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ProfileNameCommand}" CommandParameter="{x:Reference ProfileNameLabel}" />
                                    </Grid.GestureRecognizers>

                                </Grid>
                            </border:SfBorder.Content>
                        </border:SfBorder>
                    </Grid>

                    <BoxView Style="{StaticResource SeparatorStyle}" />

                    <!--  Grid for mail id label and icon  -->
                    <Grid Padding="20" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Label
                        Grid.Column="0"
                        Margin="0,5,0,0"
                        Style="{StaticResource CommonProfileIconLabelStyle}"
                        Text="{StaticResource Profile}" />

                        <StackLayout Grid.Column="1">

                            <Label Text="{Binding Medico.NombreEspecialidad}" 
                               Style="{StaticResource LabelStyle-HighlightPrimaryDarken}"/>
                            
                            <StackLayout Orientation="Horizontal" Spacing="10">
                                <Label Text="{Binding Medico.CedulaLetra}"
                                   Style="{StaticResource LabelStyle-HighlightPrimaryDarken}"/>
                                <Image Source="verificado.png" HeightRequest="20"
                                   IsVisible="{Binding Medico.CedulaVerificada}"/>
                            </StackLayout>

                            <!-- Label: Rating -->
                            <SfRating:SfRating Grid.Column="1" Grid.Row="4" Value="{Binding Medico.Rating}"
                                               RatingSettings="{StaticResource SfRatingSettings-Default}"
                                               Style="{StaticResource SfRatingStyle-ReadOnly}" />

                        </StackLayout>



                    </Grid>

                    <BoxView Style="{StaticResource SeparatorStyle}" IsVisible="{Binding MostrarProximaCita}" />

                    <!-- Grid: Próxima Cita Disponible -->
                    <Grid Padding="20" IsVisible="{Binding MostrarProximaCita}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Text="Próxima Cita Disponible" LineBreakMode="WordWrap"
                               Style="{StaticResource LabelStyle-HighlightPrimaryDarken}"/>

                        <Label Grid.Column="1" Text="{Binding ProximaCita}" LineBreakMode="WordWrap"
                               Style="{StaticResource LabelStyle-HighlightRed}"
                               HorizontalOptions="End" HorizontalTextAlignment="End"/>
                    </Grid>

                    <!-- SfButton: Agendar Cita -->
                    <button:SfButton Text="AGENDAR CITA" Command="{Binding AgendarCitaCommand}"
                                 Style="{StaticResource SfButtonStyle-WidePrimary}"/>

                </StackLayout>

                <StackLayout HorizontalOptions="FillAndExpand" Padding="20" BackgroundColor="White" Spacing="10">

                    <Label Text="Información Profesional" Style="{StaticResource LabelStyle-Highlight}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Stack Layout: Título Profesional -->
                        <StackLayout Grid.Row="0" Orientation="Horizontal" Spacing="0">
                            <Label Text="Título: " Style="{StaticResource LabelStyle-Text}"/>
                            <Label Text="{Binding Medico.TituloProfesional}" Style="{StaticResource LabelStyle-Text}"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>

                        <!-- Stack Layout: Universidad -->
                        <StackLayout Grid.Row="1" Orientation="Horizontal" Spacing="0">
                            <Label Text="Universidad: " Style="{StaticResource LabelStyle-Text}"/>
                            <Label Text="{Binding Medico.Universidad}" Style="{StaticResource LabelStyle-Text}"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>

                        <!-- Stack Layout: Especialidad -->
                        <StackLayout Grid.Row="2" Orientation="Horizontal" Spacing="0">
                            <Label Text="Especialidad: " Style="{StaticResource LabelStyle-Text}"/>
                            <Label Text="{Binding Medico.NombreEspecialidad}" Style="{StaticResource LabelStyle-Text}"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>

                        <!-- Stack Layout: Cédula Profesional -->
                        <StackLayout Grid.Row="3" Orientation="Horizontal" Spacing="0">
                            <Label Text="Ced. Prof.: " Style="{StaticResource LabelStyle-Text}"/>
                            <Label Text="{Binding Medico.Cedula}" Style="{StaticResource LabelStyle-Text}"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>

                        <!-- Stack Layout: Experiencia -->
                        <StackLayout Grid.Row="4" Orientation="Horizontal" Spacing="0">
                            <Label Text="Años de Experiencia: " Style="{StaticResource LabelStyle-Text}"/>
                            <Label Text="{Binding Medico.ExperienciaEspecialidad}" Style="{StaticResource LabelStyle-Text}"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>

                        <!-- Share -->
                        <StackLayout Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" BackgroundColor="Transparent" HeightRequest="40">
                            <border:SfBorder BackgroundColor="Transparent" BorderWidth="1" 
                                         BorderColor="{DynamicResource Primary}" CornerRadius="28" Padding="4">
                                <border:SfBorder.Content>
                                    <Image Source="share.png" HeightRequest="28" WidthRequest="28">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ShareCommand}"/>
                                        </Image.GestureRecognizers>
                                    </Image>
                                </border:SfBorder.Content>
                            </border:SfBorder>
                        </StackLayout>
                        

                    </Grid>

                </StackLayout>

                <StackLayout HorizontalOptions="FillAndExpand" Padding="20" BackgroundColor="White" Spacing="10">

                    <Label Text="Acerda de mí" Style="{StaticResource LabelStyle-Highlight}"/>
                    <Label Text="{Binding Medico.AcercadeMi}" Style="{StaticResource LabelStyle-Text}"
                                   LineBreakMode="WordWrap"/>

                </StackLayout>

                <!-- Stack Layout: Consultorios -->
                <StackLayout HorizontalOptions="FillAndExpand" Padding="20" BackgroundColor="White" Spacing="0">
                    
                    <StackLayout Orientation="Horizontal" Spacing="0">
                        <Label Text="Consultorios: " Style="{StaticResource LabelStyle-Highlight}"/>
                        <Label Text="{Binding Consultorios.Count}" Style="{StaticResource LabelStyle-HighlightPrimary}"/>
                    </StackLayout>

                    <!-- SfListView: Consultorios -->
                    <SfListView:SfListView ItemsSource="{Binding Consultorios}" Style="{StaticResource SfListViewStyle-Base}" 
                                           IsScrollBarVisible="True" HeightRequest="160">
                        <SfListView:SfListView.ItemTemplate>
                            <DataTemplate>
                                <Grid BackgroundColor="{DynamicResource White}">
                                    <Label Margin="0,10,0,0" Text="{Binding NombreConsultorio}" Style="{StaticResource LabelStyle-Text}"/>
                                </Grid>
                            </DataTemplate>
                        </SfListView:SfListView.ItemTemplate>
                    </SfListView:SfListView>

                </StackLayout>

                <!-- Stack Layout: Aseguradoras -->
                <StackLayout HorizontalOptions="FillAndExpand" Padding="20" BackgroundColor="White" Spacing="0">

                    <StackLayout Orientation="Horizontal" Spacing="0">
                        <Label Text="Aseguradoras con las que trabajo: " Style="{StaticResource LabelStyle-Highlight}"/>
                        <Label Text="{Binding Aseguradoras.Count}" Style="{StaticResource LabelStyle-HighlightPrimary}"/>
                    </StackLayout>

                    <!-- SfListView: Aseguradoras -->
                    <SfListView:SfListView ItemsSource="{Binding Aseguradoras}" Style="{StaticResource SfListViewStyle-Base}" 
                                           IsScrollBarVisible="True" HeightRequest="160">
                        <SfListView:SfListView.ItemTemplate>
                            <DataTemplate>
                                <Grid BackgroundColor="{DynamicResource White}">
                                    <Label Margin="0,10,0,0" Text="{Binding NombreAseguradora}" Style="{StaticResource LabelStyle-Text}"/>
                                </Grid>
                            </DataTemplate>
                        </SfListView:SfListView.ItemTemplate>
                    </SfListView:SfListView>

                </StackLayout>

                <!-- StackLayout: Controles de Consulta -->
                <StackLayout Orientation="Horizontal" HorizontalOptions="FillAndExpand" BackgroundColor="Transparent" Spacing="20" Padding="20">

                    <!-- SfButton: Cancelar Cita -->
                    <SfButtons:SfButton Text="VER SERVICIOS" Style="{StaticResource SfButtonStyle-BorderedTransparentButtonRed}"
                                            Command="{Binding IrServiciosCommand}"/>

                    <!-- SfButton: Modificar Cita -->
                    <SfButtons:SfButton Text="VER OPINIONES" Style="{StaticResource SfButtonStyle-BorderedTransparentButtonPrimaryDarken}"
                                            Command="{Binding IrOpinionesCommand}" />

                </StackLayout>

            </StackLayout>

        </ScrollView>
    </ContentPage.Content>
</ContentPage>