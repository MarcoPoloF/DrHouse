<?xml version="1.0" encoding="UTF-8" ?>
<!--Definición de View (XAML): Registro (dn-05-3).-->
<ContentPage
    x:Class="DocNoc.Xam.Views.Acceso.SimpleSignUpPage"
    x:Name="SignInPage"
    xmlns="http://xamarin.com/schemas/2014/forms"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:border="clr-namespace:Syncfusion.XForms.Border;assembly=Syncfusion.Core.XForms"
    xmlns:buttons="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
    xmlns:control="clr-namespace:DocNoc.Xam.Controls"
    xmlns:converter="clr-namespace:DocNoc.Xam.Converters"
    xmlns:core="clr-namespace:Syncfusion.XForms.Core;assembly=Syncfusion.Core.XForms"
    xmlns:SfBusyIndicator="clr-namespace:Syncfusion.SfBusyIndicator.XForms;assembly=Syncfusion.SfBusyIndicator.XForms"
    xmlns:SfPopupLayout="clr-namespace:Syncfusion.XForms.PopupLayout;assembly=Syncfusion.SfPopupLayout.XForms"
    xmlns:local="clr-namespace:DocNoc.Xam.Views.Acceso"
    xmlns:Styles="clr-namespace:DocNoc.Xam.Styles;assembly=DocNoc.Xam"
    Title="Sign Up"
    BackgroundColor="{DynamicResource Gray-200}"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml" />
                <!-- Resource Dictionary: Main Stylesheet -->
                <Styles:MainStylesheet/>
            </ResourceDictionary.MergedDictionaries>
            <!-- PopupLayout: WebView -->
            <SfPopupLayout:SfPopupLayout x:Key="CommentDetailPopup" IsOpen="{Binding Path=BindingContext.WebViewVisible, Source={x:Reference SignInPage}}">
                <SfPopupLayout:SfPopupLayout.PopupView >
                    <SfPopupLayout:PopupView AcceptButtonText="Cerrar" AppearanceMode="OneButton" ShowCloseButton="True" IsFullScreen="True"
                        HeaderTitle="{Binding Path=BindingContext.WebViewTitulo, Source={x:Reference SignInPage}}">
                        <SfPopupLayout:PopupView.ContentTemplate>
                            <DataTemplate>
                                <Grid VerticalOptions="FillAndExpand">
                                    <WebView Source="{Binding Path=BindingContext.WebViewRuta, Source={x:Reference SignInPage}}"/>
                                </Grid>
                            </DataTemplate>
                        </SfPopupLayout:PopupView.ContentTemplate>
                    </SfPopupLayout:PopupView>
                </SfPopupLayout:SfPopupLayout.PopupView>
            </SfPopupLayout:SfPopupLayout>
            <converter:BooleanToColorConverter x:Key="ColorConverter" />
            <converter:InverseBooleanConverter x:Key="InverseBoolean" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Content>

        <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" BackgroundColor="Transparent">
            <Grid.Padding>
                <OnPlatform x:TypeArguments="Thickness">
                    <OnPlatform.Platforms>
                        <On Platform="iOS" Value="0, 36, 0, 0" />
                    </OnPlatform.Platforms>
                </OnPlatform>
            </Grid.Padding>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="4*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Stack Layout: Signup Controls -->
            <StackLayout Grid.Row="1" HorizontalOptions="FillAndExpand" VerticalOptions="Start" BackgroundColor="Transparent"
                         Padding="20" Spacing="10">

                <!--  Entry to get first name from user  -->
                <border:SfBorder
                        BackgroundColor="{DynamicResource Gray-White}"
                        BorderColor="{Binding Source={x:Reference NameEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}"
                        Style="{StaticResource SfBorderStyle}">
                    <control:BorderlessEntry
                            x:Name="NameEntry"
                            Placeholder="{Binding PageText.FirstNamePlaceholder}"
                            PlaceholderColor="{DynamicResource Gray-700}"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding FirstName}"
                            TextColor="{DynamicResource Gray-900}" 
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}"/>
                </border:SfBorder>

                <!--  Entry to get last name from user  -->
                <border:SfBorder
                        BackgroundColor="{DynamicResource Gray-White}"
                        BorderColor="{Binding Source={x:Reference NameEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}"
                        Style="{StaticResource SfBorderStyle}">
                    <control:BorderlessEntry
                            x:Name="LastNameEntry"
                            Placeholder="{Binding PageText.LastNamePlaceholder}"
                            PlaceholderColor="{DynamicResource Gray-700}"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding LastName}"
                            TextColor="{DynamicResource Gray-900}" 
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}"/>
                </border:SfBorder>

                <!--  Entry to get email ID from user  -->
                <border:SfBorder
                        BackgroundColor="{DynamicResource Gray-White}"
                        BorderColor="{Binding Source={x:Reference EmailEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}"
                        Style="{StaticResource SfBorderStyle}">
                    <control:BorderlessEntry
                            x:Name="EmailEntry"
                            Keyboard="Email"
                            Placeholder="Email"
                            PlaceholderColor="{DynamicResource Gray-700}"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding Email}"
                            TextColor="{DynamicResource Gray-900}" 
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}"/>
                </border:SfBorder>

                <!--  Entry to get password from user  -->
                <border:SfBorder
                        BackgroundColor="{DynamicResource Gray-White}"
                        BorderColor="{Binding Source={x:Reference PasswordEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}"
                        Style="{StaticResource SfBorderStyle}">
                    <control:BorderlessEntry
                            x:Name="PasswordEntry"
                            IsPassword="true"
                            Placeholder="{Binding PageText.PasswordPlaceholder}"
                            PlaceholderColor="{DynamicResource Gray-700}"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding Password}"
                            TextColor="{DynamicResource Gray-900}" 
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}"/>
                </border:SfBorder>

                <!--  Entry to get the confirm password from user  -->
                <border:SfBorder
                        BackgroundColor="{DynamicResource Gray-White}"
                        BorderColor="{Binding Source={x:Reference ConfirmPasswordEntry}, Path=IsFocused, Converter={StaticResource ColorConverter}, ConverterParameter=3}"
                        Style="{StaticResource SfBorderStyle}">
                    <control:BorderlessEntry
                            x:Name="ConfirmPasswordEntry"
                            IsPassword="true"
                            Placeholder="{Binding PageText.ConfirmPasswordPlaceholder}"
                            PlaceholderColor="{DynamicResource Gray-700}"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding ConfirmPassword}"
                            TextColor="{DynamicResource Gray-900}" 
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}"/>
                </border:SfBorder>

                <StackLayout Orientation="Horizontal" BackgroundColor="Transparent" Margin="0,10,0,20" Spacing="10">
                    <CheckBox IsChecked="{Binding TermsAccepted}" Color="{StaticResource PrimaryColor}" VerticalOptions="Center"/>
                    <Label Text="Acepto los &lt;u&gt;Términos y Condiciones&lt;/u&gt; de DocNoc." VerticalOptions="Center" TextType="Html"
                           Style="{StaticResource LabelStyle-TextPrimaryDark}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TerminosCondicionesCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </StackLayout>

                <!--  Sign-up button  -->
                <buttons:SfButton IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolean}}" Command="{Binding SignUpCommand}"
                    FontFamily="{StaticResource Montserrat-SemiBold}" Style="{StaticResource SfButtonStyleSecondary}"
                    Text="{Binding PageText.SignUpButton}" Margin="0,20" />

                <!-- Busy Indicator: Sign-Up -->
                <SfBusyIndicator:SfBusyIndicator Title="Registrando usuario..." IsBusy="{Binding IsBusy}" Margin="20"
                                                 Style="{StaticResource SfBusyIndicatorStyle-SlicedPrimary}"/>

            </StackLayout>

            <!-- Stack Layout: Bottom Section -->
            <StackLayout Grid.Row="2" HorizontalOptions="FillAndExpand" VerticalOptions="EndAndExpand" BackgroundColor="Transparent" Padding="20">
                
                <StackLayout HorizontalOptions="CenterAndExpand" Orientation="Horizontal" Spacing="0" VerticalOptions="EndAndExpand">
                    
                    <Label
                        FontFamily="{StaticResource Montserrat-Medium}"
                        HorizontalOptions="Start"
                        HorizontalTextAlignment="Start"
                        Style="{StaticResource LabelStyle}"
                        Text="{Binding PageText.LoginText}"
                        TextColor="{DynamicResource Gray-800}"
                        VerticalTextAlignment="Center" />

                    <buttons:SfButton
                        Command="{Binding LoginCommand}"
                        HorizontalOptions="Start"
                        CornerRadius="4"
                        Margin="0"
                        Padding="0"
                        Style="{StaticResource SfFlatButtonStyle}"
                        Text="{Binding PageText.LoginLink}" />

                </StackLayout>
                
            </StackLayout>

        </Grid>
    </ContentPage.Content>
</ContentPage>