<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
xmlns:stepProgressBar="clr-namespace:Syncfusion.Maui.ProgressBar;assembly=Syncfusion.Maui.ProgressBar"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DocNoc.Xam.Controls"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             xmlns:converter="clr-namespace:DocNoc.Xam.Converters"
             xmlns:ListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
             xmlns:cards="clr-namespace:Syncfusion.Maui.Cards;assembly=Syncfusion.Maui.Cards" 
             xmlns:sfgrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid" 
             xmlns:popuplayout="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
             xmlns:SfBusyIndicator="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:Behaviors="clr-namespace:DocNoc.Xam.Behaviors"
             xmlns:Styles="clr-namespace:DocNoc.Xam.Styles;assembly=DocNoc.Xam"
             x:Class="DocNoc.Xam.Views.Citas.MyAddressPage"
             x:Name="MyAdressPage"
             BackgroundColor="{DynamicResource PageBackground}"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converter:InverseBooleanConverter x:Key="InverseBoolean" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml" />
                <!-- Resource Dictionary: Main Stylesheet -->
                <Styles:MainStylesheet/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ControlTemplate>
        <ControlTemplate>
            <StackLayout x:Name="titleLayout" Spacing="0">
                <StackLayout.Padding>
                    <OnPlatform x:TypeArguments="Thickness">
                        <OnPlatform.Platforms>
                            <On Platform="iOS" Value="0, 36, 0, 0" />
                        </OnPlatform.Platforms>
                    </OnPlatform>
                </StackLayout.Padding>
                <controls:TitleView Title="Agendar Cita">
                    <controls:TitleView.LeadingView>
                        <!-- Button: Back -->
                        <buttons:SfButton Text="{StaticResource Icon-Back}" Style="{StaticResource SfButtonStyle-Icon}"
                                            Command="{Binding Path=BindingContext.BackCommand, Source={x:Reference MyAdressPage}}" />
                    </controls:TitleView.LeadingView>
                </controls:TitleView>
                <ContentPresenter />
            </StackLayout>
        </ControlTemplate>
    </ContentPage.ControlTemplate>

    <ContentPage.Content>

        <Grid RowSpacing="5">

            <!--Definición de Renglones-->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Encabezado (Step Progress) -->
            <StackLayout Grid.Row="0" HorizontalOptions="FillAndExpand" BackgroundColor="White" Padding="5" Margin="0,2,0,0">
                <!-- SfStepProgressBar: Progreso de Agendar Cita -->
                <stepProgressBar:SfStepProgressBar HorizontalOptions="Center" VerticalOptions="Center" Orientation="Horizontal">
                    <stepProgressBar:StepView PrimaryText="DIA Y HORA" Status="{Binding Step1}"  />
                    <stepProgressBar:StepView PrimaryText="PARA QUIEN" Status="{Binding Step2}" />
                    <stepProgressBar:StepView PrimaryText="CONFIRMAR" Status="{Binding Step3}"/>
                </stepProgressBar:SfStepProgressBar>
            </StackLayout>

            <!-- StackLayout: Secciones de Agendar Cita -->
            <Grid Grid.Row="1" BackgroundColor="Transparent" >

                <!-- StackLayout: Sección 1-->
                <StackLayout VerticalOptions="FillAndExpand" Spacing="5" BackgroundColor="Transparent" HeightRequest="1200"
                             IsVisible="{Binding Seccion1Activa}">

                    <StackLayout Orientation="Horizontal" HorizontalOptions="FillAndExpand" BackgroundColor="White" Padding="10,5">
                        <!-- SfButton: Siguiente -->
                        <buttons:SfButton Text="Siguiente" Command="{Binding NextCommand}"
                                          Style="{StaticResource SfButtonStyle-RoundSecondary}" HorizontalOptions="EndAndExpand" />
                    </StackLayout>

                    <StackLayout HorizontalOptions="FillAndExpand" BackgroundColor="White" Padding="5">
                        <!-- SfListView: Días del Mes -->
                        <ListView:SfListView x:Name="listViewDias" ItemsSource="{Binding Dias}" Orientation="Horizontal" HeightRequest="60" 
                                             BackgroundColor="Transparent" AutoFitMode="Height" SelectedItem="{Binding DiaSeleccionado}">
                            <ListView:SfListView.Behaviors>
                                <Behaviors:SfListViewTapBehavior Command="{Binding Path=BindingContext.AddCardCommand, Source={x:Reference MyAdressPage}}" />
                            </ListView:SfListView.Behaviors>
                            <ListView:SfListView.ItemTemplate>
                                <DataTemplate>
                                    <StackLayout WidthRequest="60" VerticalOptions="Center" BackgroundColor="{DynamicResource White}">
                                        <Label Text="{Binding DiaSemana}" HorizontalTextAlignment="Center" TextColor="Black"/>
                                        <Label Text="{Binding FechaDia}" HorizontalTextAlignment="Center" TextColor="Black" FontAttributes="Bold"/>
                                    </StackLayout>
                                </DataTemplate>
                            </ListView:SfListView.ItemTemplate>
                            <ListView:SfListView.SelectedItemTemplate>
                                <DataTemplate>
                                    <StackLayout WidthRequest="60" VerticalOptions="Center" BackgroundColor="{DynamicResource PrimaryColor}">
                                        <Label Text="{Binding DiaSemana}" HorizontalTextAlignment="Center"  TextColor="White"/>
                                        <Label Text="{Binding FechaDia}"  HorizontalTextAlignment="Center" TextColor="White" FontAttributes="Bold"/>
                                    </StackLayout>
                                </DataTemplate>
                            </ListView:SfListView.SelectedItemTemplate>
                        </ListView:SfListView>
                    </StackLayout>

                    <!-- Stack Layout: Consultorios -->
                    <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" BackgroundColor="Transparent" Padding="0">

                        <!-- Busy Indicator: Loading -->
                        <SfBusyIndicator:SfBusyIndicator Title="Cargando horarios..." IsBusy="{Binding IsBusy}" VerticalOptions="CenterAndExpand"
                                                         Style="{StaticResource SfBusyIndicatorStyle-SlicedPrimary}"/>

                        <!-- SfListView: Consultorios -->
                        <ListView:SfListView x:Name="SfListView_Consultorios" ItemsSource="{Binding Consultorios}" HorizontalOptions="StartAndExpand"
                                             AutoFitMode="Height" BackgroundColor="Transparent" ItemSpacing="0" 
                                             IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolean}}">
                            <ListView:SfListView.ItemTemplate>
                                <DataTemplate>
                                    <StackLayout Padding="5" Margin="0,0,0,5" BackgroundColor="White">

                                        <Label Text="{Binding NombreConsultorio}" Style="{StaticResource LabelStyle-Base}" FontAttributes="Bold"/>

                                        <Label Text="{Binding Direccion}" Style="{StaticResource LabelStyle-Base}"/>

                                        <!-- SfListView: Horarios Disponibles -->
                                        <ListView:SfListView ItemsSource="{Binding CitasDisponibles}" Orientation="Horizontal" HeightRequest="40"
                                                                 SelectedItem="{Binding Path=BindingContext.HorarioSeleccionado, Source={x:Reference MyAdressPage}}"
                                                                 AutoFitMode="Height" ItemSpacing="5" IsVisible="{Binding ConConsultas}">

                                            <!--<ListView:SfListView.Behaviors>
                                                    <Behaviors:SfListViewTapBehavior Command="{Binding Path=BindingContext.HorarioSeleccionadoCommand, Source={x:Reference MyAdressPage}}" />
                                                </ListView:SfListView.Behaviors>-->

                                            <ListView:SfListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Frame BorderColor="{DynamicResource PrimaryColor}" BackgroundColor="{StaticResource Gray-White}" 
                                                           CornerRadius="5" Padding="10,0" HasShadow="False">
                                                        <Label Text="{Binding HoraConsulta}" TextColor="{DynamicResource PrimaryColor}"
                                                                   HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Frame>
                                                </DataTemplate>
                                            </ListView:SfListView.ItemTemplate>

                                            <ListView:SfListView.SelectedItemTemplate>
                                                <DataTemplate>
                                                    <Frame BorderColor="{DynamicResource PrimaryColor}" BackgroundColor="{DynamicResource PrimaryColor}" 
                                                               CornerRadius="5" Padding="10,0" HasShadow="False">
                                                        <Label Text="{Binding HoraConsulta}" TextColor="{DynamicResource Gray-White}"
                                                                   HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Frame>
                                                </DataTemplate>
                                            </ListView:SfListView.SelectedItemTemplate>

                                        </ListView:SfListView>

                                        <Label Text="No hay consultas para esta fecha." TextColor="{DynamicResource Gray-500}" FontAttributes="Italic"
                                                   IsVisible="{Binding SinConsultas}"/>

                                    </StackLayout>
                                </DataTemplate>
                            </ListView:SfListView.ItemTemplate>
                        </ListView:SfListView>


                    </StackLayout>

                </StackLayout>

                <!-- StackLayout: Sección 2-->
                <StackLayout VerticalOptions="FillAndExpand" Spacing="5" BackgroundColor="Transparent" HeightRequest="1200"
                             IsVisible="{Binding Seccion2Activa}">

                    <StackLayout Orientation="Horizontal" HorizontalOptions="FillAndExpand" BackgroundColor="White" Padding="10,5">
                        <!-- SfButton: Anterior -->
                        <buttons:SfButton Text="Anterior" Command="{Binding BackwardsCommand}" IsVisible="{Binding RetrocederVisible}" 
                                      Style="{StaticResource SfButtonStyle-RoundSecondary}" HorizontalOptions="StartAndExpand" />
                        <!-- SfButton: Siguiente -->
                        <buttons:SfButton Text="Siguiente" Command="{Binding NextCommand}"
                                          Style="{StaticResource SfButtonStyle-RoundSecondary}" HorizontalOptions="EndAndExpand" />
                    </StackLayout>

                    <StackLayout HorizontalOptions="FillAndExpand" BackgroundColor="White" Padding="10,5">
                        
                        <Label Text="¿Para quién es la cita?" Style="{StaticResource LabelStyle-Base}" FontAttributes="Bold"/>

                        <!-- SfListView: Pacientes -->
                        <ListView:SfListView x:Name="listViewPacientes" ItemsSource="{Binding Pacientes}" Orientation="Horizontal" HeightRequest="60" 
                                                 SelectedItem="{Binding PacienteSeleccionado}" AutoFitMode="DynamicHeight" ItemSpacing="5">
                            <ListView:SfListView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BorderColor="{DynamicResource PrimaryColor}" BackgroundColor="{DynamicResource Gray-White}" 
                                       CornerRadius="5" HorizontalOptions="FillAndExpand" Padding="5" HasShadow="False">
                                        <Label Text="{Binding NombreAdicional}" TextColor="{DynamicResource PrimaryColor}"
                                                   HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                </DataTemplate>
                            </ListView:SfListView.ItemTemplate>
                            <ListView:SfListView.SelectedItemTemplate>
                                <DataTemplate>
                                    <Frame BorderColor="{DynamicResource PrimaryColor}" BackgroundColor="{DynamicResource PrimaryColor}" 
                                       CornerRadius="5" HorizontalOptions="FillAndExpand" Padding="5,0" HasShadow="False">
                                        <Label Text="{Binding NombreAdicional}" TextColor="{DynamicResource Gray-White}"
                                                   HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                </DataTemplate>
                            </ListView:SfListView.SelectedItemTemplate>
                        </ListView:SfListView>

                        <inputLayout:SfTextInputLayout Hint="Para alguien más (ingrese su nombre)" >
                            <Entry Text="{Binding PacienteExterno}" TextColor="{StaticResource Black}" BackgroundColor="{StaticResource Gray-White}"/>
                        </inputLayout:SfTextInputLayout>

                        <Label Text="¿Cuál es el motivo de la cita?" Style="{StaticResource LabelStyle-Base}" FontAttributes="Bold"/>

                        <Label Text="Esto ayudará al médico a brindarte una mejor atención. Opcional." Style="{StaticResource LabelStyle-Base}"/>

                        <inputLayout:SfTextInputLayout Hint="Ingresa el motivo de la consulta." >
                            <Entry Text="{Binding MotivoConsulta}" TextColor="{StaticResource Black}" BackgroundColor="{StaticResource Gray-White}"/>
                        </inputLayout:SfTextInputLayout>

                    </StackLayout>

                </StackLayout>

                <!-- StackLayout: Sección 3-->
                <StackLayout VerticalOptions="FillAndExpand" Spacing="5" BackgroundColor="Transparent" HeightRequest="1200"
                             IsVisible="{Binding Seccion3Activa}">

                    <StackLayout Orientation="Horizontal" HorizontalOptions="FillAndExpand" BackgroundColor="White" Padding="10,5">
                        <!-- SfButton: Anterior -->
                        <buttons:SfButton Text="Anterior" Command="{Binding BackwardsCommand}" IsVisible="{Binding RetrocederVisible}" 
                                      Style="{StaticResource SfButtonStyle-RoundSecondary}" HorizontalOptions="StartAndExpand" />
                        <!-- SfButton: Agendar -->
                        <buttons:SfButton Text="Agendar" Command="{Binding FinishCommand}" IsVisible="{Binding AgendarVisible}" 
                                      Style="{StaticResource SfButtonStyle-RoundSecondary}" HorizontalOptions="EndAndExpand" />
                    </StackLayout>

                    <StackLayout HorizontalOptions="FillAndExpand" BackgroundColor="White" Padding="10">

                        <Label Text="Los datos de tu cita son:" Style="{StaticResource LabelStyle-Base}" FontAttributes="Bold"/>

                        <!-- StackLayout: Información de la Consulta -->
                        <StackLayout HorizontalOptions="FillAndExpand" Spacing="10" Padding="10" BackgroundColor="White">

                            <!-- StackLayout: Datos de la Consulta -->
                            <StackLayout HorizontalOptions="FillAndExpand">
                                <Label Text="{Binding PacienteCita}" Style="{StaticResource LabelStyle-Base}" FontAttributes="Bold"/>
                                <Label Text="{Binding CitaLetra}" Style="{StaticResource LabelStyle-Base}"/>
                            </StackLayout>

                            <!-- StackLayout: Motivo de la Consulta -->
                            <StackLayout HorizontalOptions="FillAndExpand">
                                <Label Text="Motivo de la Consulta" Style="{StaticResource LabelStyle-Base}" FontAttributes="Bold"/>
                                <Label Text="{Binding MotivoConsulta}" Style="{StaticResource LabelStyle-Base}"/>
                            </StackLayout>

                            <!-- StackLayout: Información del Consultorio -->
                            <StackLayout HorizontalOptions="FillAndExpand">
                                <Label Text="{Binding ConsultorioSeleccionado.NombreConsultorio}" Style="{StaticResource LabelStyle-Base}" FontAttributes="Bold"/>
                                <Label Text="{Binding ConsultorioSeleccionado.Direccion}" Style="{StaticResource LabelStyle-Base}"/>
                            </StackLayout>

                        </StackLayout>

                        <!-- Busy Indicator: Generando cita -->
                        <SfBusyIndicator:SfBusyIndicator Title="Agendando la cita..." IsBusy="{Binding GenerandoCita}"
                                                         Style="{StaticResource SfBusyIndicatorStyle-SlicedPrimary}"/>

                    </StackLayout>                    

                </StackLayout>

            </Grid>

        </Grid>

    </ContentPage.Content>

</ContentPage>